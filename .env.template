# EventFinder Environment Configuration Template
# Copy this file to .env and fill in your actual values
# Run 'npm run setup' for guided configuration

# =============================================================================
# API Keys and Authentication
# =============================================================================

# Example API - Get your key from https://api.example.com/signup
EXAMPLE_API_KEY=your_api_key_here

# Google Calendar API (OAuth2)
# Setup guide: https://developers.google.com/calendar/api/quickstart
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Ticketmaster API
# Get your key from https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_api_key_here

# Eventbrite API
# Get your token from https://www.eventbrite.com/platform/api
EVENTBRITE_API_TOKEN=your_token_here

# =============================================================================
# Optional Configuration
# =============================================================================

# Default search parameters
DEFAULT_SEARCH_RADIUS=25
DEFAULT_RESULT_LIMIT=10

# Cache settings
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600

# =============================================================================
# MCP Server Configuration
# =============================================================================

# Custom MCP server endpoints
# MCP_CUSTOM_SERVER_URL=https://your-mcp-server.com
# MCP_CUSTOM_SERVER_TOKEN=your_token_here
